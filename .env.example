# Sanity metadata store
SANITY_PROJECT_ID=snnkgi7q
SANITY_DATASET=production
NEXT_PUBLIC_SANITY_PROJECT_ID=snnkgi7q
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_TOKEN=
CAST_PLATFORM_ENTRY_SECRET=
CAST_PLATFORM_SESSION_MAX_AGE=28800

# Optional: keep true for standalone/local studio access, false for production platform-only auth.
CAST_ALLOW_ACCESS_CODE_FALLBACK=

# Distribution worker
# Preferred secret for an external scheduler that calls /api/distribution/cron.
CAST_DISTRIBUTION_WORKER_SECRET=
# Legacy fallback that is also accepted when the preferred secret is empty.
CRON_SECRET=
CAST_DISTRIBUTION_BATCH_SIZE=4

# Media object storage
OBJECT_STORAGE_ACCOUNT_ID=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_PUBLIC_BASE_URL=

# Optional override. If left empty, the upload endpoint is derived from the account id.
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_SIGNED_URL_EXPIRES_IN=900

# Public app origin fallback for connector jobs
PUBLIC_SITE_ORIGIN=

# YouTube connector fallback
# These values are used when a tenant has no stored connector credentials.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=28

# Instagram Reels connector fallback
# Used when a tenant has no stored Instagram connector credentials.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_API_VERSION=v23.0

# TikTok connector fallback
# Used when a tenant has no stored TikTok connector credentials.
TIKTOK_ACCESS_TOKEN=
TIKTOK_POST_MODE=direct
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_DISABLE_DUET=
TIKTOK_DISABLE_COMMENT=
TIKTOK_DISABLE_STITCH=

# Optional ffmpeg overrides for the clip renderer
FFMPEG_PATH=
FFMPEG_FONT_FILE=
